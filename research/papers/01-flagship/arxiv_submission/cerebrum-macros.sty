\newcommand{\REMEngine}{\textsc{REM Engine}}
\newcommand{\CSA}{\textsc{CSA}}
\newcommand{\DSCF}{\textsc{DSCF}}
\newcommand{\TSC}{\textsc{TSC}}
\newcommand{\BeamTraversal}{\texttt{BeamTraversal}}
\newcommand{\GraphSnapshot}{\texttt{GraphSnapshot}}
\newcommand{\ProvenanceLedger}{\texttt{ProvenanceLedger}}
\newcommand{\AutoApprover}{\texttt{AutoApprover}}
