{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "CEREBRUM Knowledge Graph Reasoning — operational monitoring",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}]}},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "id": 1,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "title": "Queries / min",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(cerebrum_queries_total[1m]) * 60",
          "legendFormat": "qpm",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "unit": "ms",
          "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 200}, {"color": "red", "value": 1000}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "title": "p95 Latency",
      "type": "stat",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(cerebrum_query_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "green", "value": 0.7}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "id": 3,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "title": "Avg Confidence",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(cerebrum_answer_confidence_sum[5m]) / rate(cerebrum_answer_confidence_count[5m])",
          "legendFormat": "confidence",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "blue", "value": null}]}}, "overrides": []},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "id": 4,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "value"},
      "title": "Graph Nodes",
      "type": "stat",
      "targets": [{"expr": "cerebrum_graph_nodes", "legendFormat": "nodes", "refId": "A"}]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "purple", "value": null}]}}, "overrides": []},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "id": 5,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "value"},
      "title": "Active Tenants",
      "type": "stat",
      "targets": [{"expr": "cerebrum_active_tenants", "legendFormat": "tenants", "refId": "A"}]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2, "fillOpacity": 10}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 10,
      "options": {"tooltip": {"mode": "multi"}},
      "title": "Query Rate (by status)",
      "type": "timeseries",
      "targets": [
        {"expr": "rate(cerebrum_queries_total{status='ok'}[1m]) * 60", "legendFormat": "ok", "refId": "A"},
        {"expr": "rate(cerebrum_queries_total{status='error'}[1m]) * 60", "legendFormat": "error", "refId": "B"},
        {"expr": "rate(cerebrum_queries_total{status='partial'}[1m]) * 60", "legendFormat": "partial", "refId": "C"}
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2, "fillOpacity": 10}, "unit": "ms"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 11,
      "options": {"tooltip": {"mode": "multi"}},
      "title": "Query Latency Percentiles",
      "type": "timeseries",
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(cerebrum_query_latency_seconds_bucket[5m])) * 1000", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, rate(cerebrum_query_latency_seconds_bucket[5m])) * 1000", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, rate(cerebrum_query_latency_seconds_bucket[5m])) * 1000", "legendFormat": "p99", "refId": "C"}
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2, "fillOpacity": 10}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "id": 12,
      "options": {"tooltip": {"mode": "multi"}},
      "title": "Beam Paths Explored / min",
      "type": "timeseries",
      "targets": [
        {"expr": "rate(cerebrum_paths_explored_total[1m]) * 60", "legendFormat": "paths/min", "refId": "A"}
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2, "fillOpacity": 10}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "id": 13,
      "options": {"tooltip": {"mode": "multi"}},
      "title": "Answer Confidence Distribution (avg)",
      "type": "timeseries",
      "targets": [
        {"expr": "rate(cerebrum_answer_confidence_sum[5m]) / rate(cerebrum_answer_confidence_count[5m])", "legendFormat": "avg confidence", "refId": "A"}
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2, "fillOpacity": 10}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "id": 14,
      "options": {"tooltip": {"mode": "multi"}},
      "title": "Hop Depth Distribution (avg)",
      "type": "timeseries",
      "targets": [
        {"expr": "rate(cerebrum_hop_depth_sum[5m]) / rate(cerebrum_hop_depth_count[5m])", "legendFormat": "avg hop depth", "refId": "A"}
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2, "fillOpacity": 10}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "id": 15,
      "options": {"tooltip": {"mode": "multi"}},
      "title": "Active API Keys & Tenants",
      "type": "timeseries",
      "targets": [
        {"expr": "cerebrum_api_keys_active", "legendFormat": "active keys", "refId": "A"},
        {"expr": "cerebrum_active_tenants", "legendFormat": "tenants", "refId": "B"},
        {"expr": "cerebrum_audit_records_total", "legendFormat": "audit records", "refId": "C"}
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["cerebrum", "kgqa"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "CEREBRUM — Operational Dashboard",
  "uid": "cerebrum-main",
  "version": 1
}
